# ==========================================================
# Civic Reporter - Environment Variables
# ==========================================================
# Copy this file to server/.env and fill in real values.
# DO NOT commit your real .env file.

# ---- Server / Database ----
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/civic-reporter?retryWrites=true&w=majority

# ---- Auth ----
# Use a long random string in production (e.g. `openssl rand -hex 64`)
JWT_SECRET=change_me_to_a_long_random_string

# Set to "true" if you want the /register endpoint to allow creating admin users
# (recommended: leave false in production and promote users manually in DB)
ALLOW_ADMIN_REGISTRATION=false

# ---- CORS ----
CLIENT_URL=http://localhost:5173

# ---- Cloudinary (image storage) ----
# Sign up at https://cloudinary.com (free tier is enough)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Google Gemini (AI categorization) ----
# Free tier: ~15 requests/min, 1,500/day — no credit card required.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the model. Default is gemini-2.0-flash (fastest free model).
# Other free options: gemini-1.5-flash, gemini-2.5-flash
# GEMINI_MODEL=gemini-2.0-flash

# ---- SMTP (email notifications) ----
# Example: Gmail with an App Password, or any SMTP provider (Sendgrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Civic Reporter <noreply@civic-reporter.app>"


# ==========================================================
# Client (.env file in /client folder, optional)
# ==========================================================
# When using Vite proxy in dev, you can leave this blank.
# In production, set it to your deployed backend URL.
# VITE_API_URL=https://your-backend.onrender.com/api
